{
  "name": "@taqwright/taqwright",
  "version": "0.1.0-beta.0",
  "description": "E2E mobile testing on the Playwright runner",
  "license": "Apache-2.0",
  "homepage": "https://www.taqwright.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taqelah/taqwright.git"
  },
  "bugs": {
    "url": "https://github.com/taqelah/taqwright/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "taqwright": "dist/bin/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "@wdio/config": {
      "glob": "^13"
    }
  },
  "scripts": {
    "build": "tsc --build && node scripts/copy-assets.mjs",
    "clean": "tsc --build --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:coverage": "npm run build && node --test --experimental-test-coverage test/*.test.js",
    "coverage:lcov": "tsc -p tsconfig.coverage.json && c8 --reporter=lcovonly --reporter=text node --test test/*.test.js",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run clean && rm -rf dist && npm run build",
    "version": "node scripts/sync-readme-version.mjs && git add README.md"
  },
  "keywords": [
    "e2e",
    "automation",
    "ios",
    "android",
    "mobile",
    "testing",
    "playwright",
    "appium"
  ],
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "commander": "^15.0.0",
    "node-forge": "^1.3.1",
    "undici": "^6.27.0",
    "webdriver": "^9.27.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/node-forge": "^1.3.11",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0"
  }
}
